<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Lab5.Views.SectionPage1"
             Title="Розклад"
             BackgroundColor="{StaticResource Primary}">
    <ScrollView>
        <Grid RowDefinitions="*,Auto">

            <VerticalStackLayout Grid.Row="0" Padding="20" Spacing="14">

                <Label Text="📅 Розклад занять" FontSize="26" FontAttributes="Bold"
                       TextColor="{StaticResource Accent}" HorizontalOptions="Center"/>

                <Border BackgroundColor="{StaticResource Secondary}"
                        StrokeShape="RoundRectangle 12" Stroke="Transparent" Padding="16">
                    <Grid ColumnDefinitions="60,*">
                        <Label Text="Пн" FontAttributes="Bold" TextColor="{StaticResource Accent}"
                               FontSize="16" VerticalOptions="Center"/>
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Силове тренування - 09:00" TextColor="{StaticResource Gray200}"/>
                            <Label Text="Йога - 18:30" TextColor="{StaticResource Gray200}"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <Border BackgroundColor="{StaticResource Secondary}"
                        StrokeShape="RoundRectangle 12" Stroke="Transparent" Padding="16">
                    <Grid ColumnDefinitions="60,*">
                        <Label Text="Вт" FontAttributes="Bold" TextColor="{StaticResource Accent}"
                               FontSize="16" VerticalOptions="Center"/>
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Кардіо - 10:00" TextColor="{StaticResource Gray200}"/>
                            <Label Text="Бокс - 19:00" TextColor="{StaticResource Gray200}"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <Border BackgroundColor="{StaticResource Secondary}"
                        StrokeShape="RoundRectangle 12" Stroke="Transparent" Padding="16">
                    <Grid ColumnDefinitions="60,*">
                        <Label Text="Ср" FontAttributes="Bold" TextColor="{StaticResource Accent}"
                               FontSize="16" VerticalOptions="Center"/>
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Силове тренування - 09:00" TextColor="{StaticResource Gray200}"/>
                            <Label Text="Пілатес - 17:00" TextColor="{StaticResource Gray200}"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <Border BackgroundColor="{StaticResource Secondary}"
                        StrokeShape="RoundRectangle 12" Stroke="Transparent" Padding="16">
                    <Grid ColumnDefinitions="60,*">
                        <Label Text="Чт" FontAttributes="Bold" TextColor="{StaticResource Accent}"
                               FontSize="16" VerticalOptions="Center"/>
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Кросфіт - 08:00" TextColor="{StaticResource Gray200}"/>
                            <Label Text="Розтяжка - 20:00" TextColor="{StaticResource Gray200}"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <Border BackgroundColor="{StaticResource Secondary}"
                        StrokeShape="RoundRectangle 12" Stroke="Transparent" Padding="16">
                    <Grid ColumnDefinitions="60,*">
                        <Label Text="Пт" FontAttributes="Bold" TextColor="{StaticResource Accent}"
                               FontSize="16" VerticalOptions="Center"/>
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Силове тренування - 09:00" TextColor="{StaticResource Gray200}"/>
                            <Label Text="Зумба - 18:00" TextColor="{StaticResource Gray200}"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <Button Text="Довідка" Clicked="OnHelpClicked"
                        BackgroundColor="{StaticResource Secondary}"
                        TextColor="{StaticResource Accent}" CornerRadius="10"/>

            </VerticalStackLayout>

            <VerticalStackLayout Grid.Row="1" Padding="0,0,0,10">
                <BoxView HeightRequest="1" Color="{StaticResource Secondary}"/>
                <Label Text="© All rights reserved by Valeriia"
                       FontSize="11" TextColor="{StaticResource Gray500}"
                       HorizontalOptions="Center" Margin="0,4,0,0"/>
            </VerticalStackLayout>

        </Grid>
    </ScrollView>
</ContentPage>
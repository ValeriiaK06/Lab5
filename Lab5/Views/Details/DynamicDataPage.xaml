<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Lab5.Views.Details.DynamicDataPage"
             Title="Детальніше"
             BackgroundColor="{StaticResource Primary}">
    <ScrollView>
        <Grid RowDefinitions="*,Auto">

            <VerticalStackLayout Grid.Row="0" Padding="20" Spacing="14">

                <Label Text="📋 Детальна інформація" FontSize="24" FontAttributes="Bold"
                       TextColor="{StaticResource Accent}" HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"/>

                <Border BackgroundColor="{StaticResource Secondary}"
                        StrokeShape="RoundRectangle 12" Stroke="Transparent" Padding="14">
                    <Label x:Name="InfoLabel" FontSize="15"
                           TextColor="{StaticResource Gray300}"
                           HorizontalTextAlignment="Center"/>
                </Border>

                <Label x:Name="DynamicContent" FontSize="15"
                       TextColor="{StaticResource Gray200}"
                       HorizontalTextAlignment="Center"/>

                <Button Text="← Назад" Clicked="OnBackClicked"
                        BackgroundColor="{StaticResource Secondary}"
                        TextColor="{StaticResource Accent}" CornerRadius="10"
                        Margin="0,10,0,0"/>

            </VerticalStackLayout>

            <VerticalStackLayout Grid.Row="1" Padding="0,0,0,10">
                <BoxView HeightRequest="1" Color="{StaticResource Secondary}"/>
                <Label Text="© All rights reserved by Valeriia"
                       FontSize="11" TextColor="{StaticResource Gray500}"
                       HorizontalOptions="Center" Margin="0,4,0,0"/>
            </VerticalStackLayout>

        </Grid>
    </ScrollView>
</ContentPage>
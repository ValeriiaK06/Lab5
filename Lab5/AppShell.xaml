<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Lab5.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Lab5"
    xmlns:views="clr-namespace:Lab5.Views"
    Title="Lab5"
    Shell.NavBarHasShadow="False"
    FlyoutBehavior="Flyout">


    <Shell.FlyoutHeader>
        <Grid HeightRequest="120" BackgroundColor="{StaticResource Primary}" Padding="20">
            <VerticalStackLayout VerticalOptions="End" Spacing="2">
                <Label Text="💪 PowerZone" TextColor="{StaticResource Accent}"
                   FontSize="22" FontAttributes="Bold"/>
                <Label Text="Спортивна зала" TextColor="{StaticResource Gray300}"
                   FontSize="13"/>
            </VerticalStackLayout>
        </Grid>
    </Shell.FlyoutHeader>


    <FlyoutItem Title="Головна (розділ 1)" Route="section1">
        <Tab Title="Вкладки">
            <ShellContent Title="Головна" Route="mainpage" ContentTemplate="{DataTemplate views:MainSectionPage}" />
            <ShellContent Title="Розклад" Route="page1" ContentTemplate="{DataTemplate views:SectionPage1}" />
        </Tab>
    </FlyoutItem>

    <FlyoutItem Title="Тренажери (розділ 2)" Route="section2">
        <ShellContent ContentTemplate="{DataTemplate views:SectionPage2}" />
    </FlyoutItem>

    <FlyoutItem Title="Абонементи (розділ 3)" Route="section3">
        <ShellContent ContentTemplate="{DataTemplate views:SectionPage3}" />
    </FlyoutItem>

    <!--<ShellContent
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />-->

</Shell>
